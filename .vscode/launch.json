{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (Nest)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start:dev",
      "cwd": "${workspaceFolder}/NestApi"
    },
    {
      "name": "Backend (dotnet)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/SampleApi/bin/Debug/net10.0/SampleApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/SampleApi",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Frontend (npm)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "cwd": "${workspaceFolder}/sample-front",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+(http://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Frontend (npm - SampleApi)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:sampleapi"],
      "cwd": "${workspaceFolder}/sample-front",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+(http://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Backend (Docker debug)",
      "type": "docker",
      "request": "launch",
      "preLaunchTask": "docker-run: debug",
      "platform": "netCore",
      "sourceFileMap": {
        "/app": "${workspaceFolder}/SampleApi"
      },
      "netCore": {
        "appProject": "${workspaceFolder}/SampleApi/SampleApi.csproj"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Backend (Nest)", "Frontend (npm)"]
    },
    {
      "name": "Full Stack (.NET)",
      "configurations": ["Backend (dotnet)", "Frontend (npm - SampleApi)"]
    }
  ]
}
